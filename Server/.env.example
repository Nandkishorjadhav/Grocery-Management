# Server Configuration
PORT=5000
NODE_ENV=production

# MongoDB Atlas Connection
# Use ONE of these:
# Option 1: SRV Connection (recommended if DNS works)
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/?appName=Cluster0

# Option 2: Standard Connection (if SRV fails)
# MONGODB_URI=mongodb://username:password@cluster0-shard-00-00.xxxxx.mongodb.net:27017,cluster0-shard-00-01.xxxxx.mongodb.net:27017,cluster0-shard-00-02.xxxxx.mongodb.net:27017/?ssl=true&replicaSet=atlas-xxx&authSource=admin

# JWT Configuration
JWT_SECRET=your_very_long_random_secret_key_here_min_32_chars

# Email Configuration (Gmail)
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your_gmail_app_password_here
EMAIL_FROM_NAME=Grocery Management

# SMS Configuration (MSG91 for India)
SMS_PROVIDER=msg91
DEFAULT_COUNTRY_CODE=+91
MSG91_AUTH_KEY=your_msg91_auth_key_here
MSG91_SENDER_ID=MSGIND
MSG91_ROUTE=4
